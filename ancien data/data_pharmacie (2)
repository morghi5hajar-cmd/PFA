import pandas as pd
import numpy as np
import random

#chargement des données
df = pd.read_excel("dataset/fichier/ref-des-medicaments-cnops-2014.xlsx", engine="openpyxl")

df = df.rename(columns={
    df.columns[1]: "drug_name",
    df.columns[7]: "price"
})

df = df[["drug_name", "price"]].dropna()
#autres variables
regions = ["Rabat", "Casablanca", "Marrakech", "Fes", "Tanger"]
pharmacies = [f"pharma_{i}" for i in range(1, 21)]

pharmacy_region = {
    pharmacy: random.choice(regions)
    for pharmacy in pharmacies
}


def get_season(month):
    if month in [12, 1, 2]:
        return "winter"
    elif month in [3, 4, 5]:
        return "spring"
    elif month in [6, 7, 8]:
        return "summer"
    else:
        return "autumn"


def generate_temperature(month):
    if month in [12, 1, 2]:
        return np.random.normal(12, 3)
    elif month in [6, 7, 8]:
        return np.random.normal(30, 3)
    else:
        return np.random.normal(20, 4)



#generation dataset
data = []

dates = pd.date_range(start="2023-01-01", end="2023-12-31")

meds_per_day = 50

for date in dates:
    
    month = date.month
    season = get_season(month)
    temperature = generate_temperature(month)

    sampled_meds = df.sample(meds_per_day, replace=True)

    for _, row in sampled_meds.iterrows():

        pharmacy = random.choice(pharmacies)
        region = pharmacy_region[pharmacy]
        


        data.append({
            "date": date,
            "drug_name": row["drug_name"],
            "price": row["price"],
            "pharmacy_id": pharmacy,
            "region": region,
            "temperature": round(temperature, 1),
            "season": season,
            
           
        })


df_final = pd.DataFrame(data)


df_final.to_csv("pharmacie_dataset2.csv", index=False, sep=";")

print("Dataset généré avec succès :", df_final.shape)
print(df_final.head())